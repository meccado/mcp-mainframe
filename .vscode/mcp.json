{
  "$schema": "https://raw.githubusercontent.com/microsoft/vscode/main/extensions/mcp/schemas/mcp.json",
  "servers": {
    "mainframe-cobol": {
      "type": "stdio",
      "command": "python",
      "args": ["${workspaceFolder}/src/mcp_server/server.py"],
      "env": {
        "BACKEND": "SSH",
        "MF_HOST": "zos.yourcompany.com",
        "MF_USER": "YOURUSERID",
        "MF_KEYFILE": "${env:HOME}/.ssh/id_rsa",
        "COBOL_SRC_DSN": "YOUR.COBOL.SRC",
        "COPYBOOK_DSN": "YOUR.COPYBOOK",
        "LOG_LEVEL": "INFO",
        "MAX_CONNECTIONS": "10",
        "CONNECTION_TIMEOUT": "30",
        "FREQUENT_PROGRAMS": "PAYROLL,BILLING,CUSTUPD",
        "FREQUENT_COPYBOOKS": "CUST-REC,ORDER-REC,COMMON1"
      }
    }
  }
}
