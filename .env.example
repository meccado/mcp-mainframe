# MCP COBOL Server Environment Configuration
# Copy this file to .env and fill in your connection details
# NEVER commit .env file to version control!

# =============================================================================
# BACKEND SELECTION
# =============================================================================
# Choose one backend: SSH, ENDEVOR, ZOSMF, or ZOWE
# SSH: Direct SSH connection to mainframe USS filesystem
# ENDEVOR: CA Endevor API web services
# ZOSMF: IBM z/OS Management Facility REST API (recommended if available)
# ZOWE: Open Mainframe Project API ML (recommended for modern DevOps)

BACKEND=SSH
# BACKEND=ENDEVOR
# BACKEND=ZOSMF
# BACKEND=ZOWE

# =============================================================================
# SSH BACKEND CONFIGURATION (Required if BACKEND=SSH)
# =============================================================================

# Mainframe Connection (Required for SSH)
MF_HOST=zos.yourcompany.com
MF_USER=YOURUSERID
MF_KEYFILE=/path/to/your/private/ssh/key

# Dataset Names (Required for SSH)
COBOL_SRC_DSN=YOUR.COBOL.SRC
COPYBOOK_DSN=YOUR.COPYBOOK

# =============================================================================
# ENDEVOR BACKEND CONFIGURATION (Required if BACKEND=ENDEVOR)
# =============================================================================

# Endevor API URL (Required for Endevor)
# Example: https://endevor.yourcompany.com/api/v1
ENDEVOR_BASE_URL=https://endevor.yourcompany.com/api/v1

# Endevor Credentials (Required for Endevor)
ENDEVOR_USER=YOURUSERID
ENDEVOR_PASSWORD=your_password_or_access_token

# Endevor Stage (Optional, default: PROD)
# Common values: PROD, TEST, DEV, UAT
ENDEVOR_STAGE=PROD

# Dataset names are optional with Endevor (used for logging only)
# COBOL_SRC_DSN=YOUR.COBOL.SRC
# COPYBOOK_DSN=YOUR.COPYBOOK

# =============================================================================
# ZOSMF BACKEND CONFIGURATION (Required if BACKEND=ZOSMF)
# =============================================================================

# z/OSMF API URL (Required for z/OSMF)
# Example: https://zosmf.yourcompany.com:10443
ZOSMF_BASE_URL=https://zosmf.yourcompany.com:10443

# z/OSMF Credentials (Required for z/OSMF)
ZOSMF_USER=YOURUSERID
ZOSMF_PASSWORD=your_password

# Dataset Names (Required for z/OSMF)
COBOL_SRC_DSN=YOUR.COBOL.SRC
COPYBOOK_DSN=YOUR.COPYBOOK

# SSL Certificate Verification (Optional, default: true)
# Set to false for development with self-signed certificates
ZOSMF_VERIFY_CERT=true

# =============================================================================
# ZOWE BACKEND CONFIGURATION (Required if BACKEND=ZOWE)
# =============================================================================

# Zowe API ML URL (Required for Zowe)
# Example: https://zowe.yourcompany.com:10010
ZOWE_BASE_URL=https://zowe.yourcompany.com:10010

# Zowe Credentials (Required for Zowe)
ZOWE_USER=YOURUSERID
ZOWE_PASSWORD=your_password

# Dataset Names (Required for Zowe)
COBOL_SRC_DSN=YOUR.COBOL.SRC
COPYBOOK_DSN=YOUR.COPYBOOK

# SSL Certificate Verification (Optional, default: true)
# Set to false for development with self-signed certificates
ZOWE_VERIFY_CERT=true

# =============================================================================
# OPTIONAL CONFIGURATION (Both Backends)
# =============================================================================

# Logging verbosity: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# Maximum concurrent connections (SSH only, 1-20)
MAX_CONNECTIONS=10

# Connection timeout in seconds
CONNECTION_TIMEOUT=30

# =============================================================================
# RESOURCES CONFIGURATION (MCP Resources for frequently accessed data)
# =============================================================================

# Frequently accessed programs (comma-separated list)
# These programs will be exposed as MCP resources for quick access
# Example: FREQUENT_PROGRAMS=PAYROLL,BILLING,CUSTUPD,INVOICE
FREQUENT_PROGRAMS=

# Frequently accessed copybooks (comma-separated list)
# Example: FREQUENT_COPYBOOKS=CUST-REC,ORDER-REC,COMMON1,DATEFLDS
FREQUENT_COPYBOOKS=

# =============================================================================
# SECURITY NOTES
# =============================================================================
# - SSH key file should have permissions 600 (read/write for owner only)
# - Never commit .env file to version control (it's in .gitignore)
# - For Endevor, consider using access tokens instead of passwords
# - Rotate credentials regularly according to your organization's policy
